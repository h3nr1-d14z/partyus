{
  "functions": {
    "src/app/app-ads.txt/route.ts": {
      "maxDuration": 10
    },
    "src/app/policies/route.ts": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/app-ads.txt",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/policies",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    }
  ]
}